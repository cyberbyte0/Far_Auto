# ===========================
# Far_Auto — .gitignore
# ===========================

# ---------- Gradle ----------
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ---------- Android Studio / IntelliJ IDEA ----------
.idea/workspace.xml
.idea/caches/
.idea/libraries/
.idea/modules.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
.idea/deploymentTargetSelector.xml
.idea/deviceManager.xml
*.iml
*.iws

# Keep shared run configurations
# .idea/runConfigurations/ is tracked by default

# ---------- Local configuration (machine-specific) ----------
local.properties

# ---------- Build outputs & APKs ----------
*.apk
*.aab
*.ap_
*.dex

# ---------- Signing ----------
*.jks
*.keystore
release/

# ---------- Chaquopy / Python cache ----------
**/__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/

# ---------- OS junk ----------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*~

# ---------- Git-related ignore ----------

.idea/

# ---------- Local configuration (machine-specific) ----------
local.properties

# ---------- Build outputs & APKs ----------
*.apk
*.aab
*.ap_
*.dex
app/build/
*/build/


# ---------- Non-Essential / Personal / Dev Docs ----------
.gemini/
/GEMINI.md
/RULES.md
/TASKS.md
/FULL_DOCS.md
/Far_Auto_Documentation.md
architecture.md
*.docx
/*.png
/*.jpg
/*.jpeg
/Screenshot*.png
/Screenshot*.jpg

