# ---------- Gradle ----------
.gradle/
build/
app/build/
*/build/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ---------- Android Studio / IntelliJ IDEA ----------
.idea/
*.iml
*.iws
captures/
.externalNativeBuild/
.cxx/

# ---------- Other editors / AI tooling ----------
.vscode/
.claude/
.gemini/
.kotlin/

# ---------- Local configuration (machine-specific) ----------
local.properties

# ---------- Build outputs & APKs ----------
*.apk
*.aab
*.ap_
*.dex
*.hprof

# ---------- Signing ----------
*.jks
*.keystore
release/

# ---------- Chaquopy / Python cache ----------
**/__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/

# ---------- OS junk ----------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*~

# ---------- Non-Essential / Personal / Dev Docs ----------
/GEMINI.md
/RULES.md
/TASKS.md
/FULL_DOCS.md
/Far_Auto_Documentation.md
/CLAUDE.md
architecture.md
*.docx
/*.png
/*.jpg
/*.jpeg
/Screenshot*.png
/Screenshot*.jpg
/ONBOARDING.md
/ACTION_RECORDING_GUIDE.md

# ---------- Decompiled / reverse-engineering scratch ----------
ascript_decompiled/

