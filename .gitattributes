# ===========================
# Far_Auto — .gitattributes
# ===========================

# Auto-detect text files and normalise line endings
* text=auto

# Force Unix line endings for all source code
*.kt        text eol=lf
*.java       text eol=lf
*.xml        text eol=lf
*.py         text eol=lf
*.gradle     text eol=lf
*.properties text eol=lf
*.md         text eol=lf
*.json       text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.toml       text eol=lf

# Shell scripts — must stay LF
*.sh         text eol=lf
gradlew      text eol=lf

# Windows batch — keep CRLF
*.bat        text eol=crlf
gradlew.bat  text eol=crlf

# Binaries — never diff, never merge
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.webp       binary
*.ico        binary
*.jar        binary
*.aar        binary
*.apk        binary
*.so         binary
*.docx       binary
